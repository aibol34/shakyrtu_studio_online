[Unit]
Description=ToiGallery Flask (Gunicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/shakyrtu_studio_online
Environment="PATH=/var/www/shakyrtu_studio_online/venv/bin"
EnvironmentFile=-/var/www/shakyrtu_studio_online/.env
ExecStart=/var/www/shakyrtu_studio_online/venv/bin/gunicorn -c gunicorn.conf.py wsgi:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
